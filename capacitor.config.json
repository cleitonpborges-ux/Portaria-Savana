{
  "appId": "io.github.cleitonpborges_ux.portaria_savana",
  "appName": "Portaria Savana",
  "webDir": "www",
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "FirebaseMessaging": {
      "presentationOptions": ["badge", "sound", "alert"],
      "channels": [
        {
          "id": "high_importance_channel",
          "name": "Portaria Savana",
          "importance": 5,
          "sound": "default",
          "vibration": true,
          "lights": true,
          "lightColor": "#0f2040",
          "visibility": 1
        }
      ]
    }
  }
}
